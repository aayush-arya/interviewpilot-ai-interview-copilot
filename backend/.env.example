# --- Core ---
ENV=development
SECRET_KEY=change-me-in-production
# SQLite by default; for Postgres:
# DATABASE_URL=postgresql://copilot:copilot@localhost:5432/interview_copilot
DATABASE_URL=sqlite:///./interview_copilot.db
CORS_ORIGINS=http://localhost:5175,http://localhost:5173

# --- AI (leave key empty to run in offline mock mode) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MODEL_DEEP=claude-sonnet-4-6

# --- Optional infra ---
REDIS_URL=
# SMTP for password-reset emails (console fallback if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@interviewpilot.dev

# --- OAuth (endpoints return 501 until set) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8002

# --- Frontend base (used in reset-password links) ---
FRONTEND_URL=http://localhost:5175
